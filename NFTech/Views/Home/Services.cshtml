                        <img src="~/images/battery.jpg" alt="Network architecture" class="w-full h-full object-cover grayscale transition-premium">
                    </div>
                    <div>
                        <span class="text-[0.8rem] font-bold uppercase tracking-[2px] text-accent-red mb-[12px] block">Division 01</span>
