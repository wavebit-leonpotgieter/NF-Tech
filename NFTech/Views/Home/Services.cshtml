            .sidebar-link.active .sidebar-badge { background: theme('colors.white'); color: theme('colors.accent-red'); }
            .cap-card::before {
                content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 3px; background-color: transparent; transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            }
            .cap-card:hover { border-color: rgba(255,255,255,0.15); transform: translateY(-4px); box-shadow: 0 15px 35px rgba(0,0,0,0.4); }
            .cap-card:hover::before { background-color: theme('colors.accent-red'); }
            .cap-card h4::before {
                content: ''; width: 8px; height: 8px; border-radius: 50%; background-color: theme('colors.accent-red'); display: inline-block;
            }
