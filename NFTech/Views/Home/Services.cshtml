            <a href="/home/services?id=network" data-target="network" class="sidebar-link active flex items-center p-[10px_18px] lg:p-[12px_24px] rounded-[50px] text-white no-underline text-[0.85rem] lg:text-[0.9rem] font-semibold bg-transparent border border-transparent transition-premium gap-[12px] whitespace-nowrap hover:bg-white/5 [&.active]:bg-accent-red [&.active]:shadow-[0_8px_20px_rgba(183,28,28,0.3)]">
                <div class="sidebar-badge w-[24px] h-[24px] bg-white/10 flex items-center justify-center font-display text-[0.75rem] font-bold rounded-full transition-premium">01</div> Network
            </a>
            <a href="/home/services?id=infrastructure" data-target="infrastructure" class="sidebar-link flex items-center p-[10px_18px] lg:p-[12px_24px] rounded-[50px] text-white no-underline text-[0.85rem] lg:text-[0.9rem] font-semibold bg-transparent border border-transparent transition-premium gap-[12px] whitespace-nowrap hover:bg-white/5 [&.active]:bg-accent-red [&.active]:shadow-[0_8px_20px_rgba(183,28,28,0.3)]">
