@{
    ViewData["Title"] = "Service Catalog";
    // Allow JS to pick up initial section to scroll to
    var targetDivision = ViewData["TargetDivision"]?.ToString();
}
<div id="initial-target" data-target="@targetDivision" style="display:none;"></div>

<!-- Services Header Hero -->
<section class="pt-[150px] lg:pt-[180px] pb-[60px] border-b border-border-color bg-[#040911] content-section">
    <div class="container-inner">
        <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_0.8fr] gap-[30px] lg:gap-[60px] items-center">
            <div>
                <span class="text-[0.8rem] font-bold uppercase tracking-[3px] text-accent-red mb-[12px] block">Full Business Scope</span>
                <h1 class="text-[2.3rem] lg:text-[4rem] font-bold tracking-[-2px] leading-[1.1] mb-[24px]">Comprehensive IT Services in South Africa</h1>
                <p class="text-[1.2rem] text-light-gray opacity-80 max-w-[680px]">Explore the full suite of specialized technology subdivisions we manage to ensure robust, efficient, and reliable IT operations for your enterprise.</p>
            </div>
        </div>
    </div>
</section>

<!-- Division Explorer Layout -->
